ENV=development
PORT=5000

# Mail Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password

# JWT Secret
JWT_SECRET=your-very-strong-jwt-secret

# Base URL
BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=lms
DB_USE_SSL=auto

# Replication / Read-Write Split
DB_WRITE_HOST=127.0.0.1
DB_WRITE_PORT=3307
DB_READ_HOST=127.0.0.1
DB_READ_PORT=3308
DB_ROLE_STATE_FILE=./tmp/db-role-state.json
DB_ENABLE_READ_WRITE_SPLIT=false
DB_ENABLE_AUTOMATIC_FAILOVER=false
DB_READ_AFTER_WRITE_MS=0
DB_HEALTHCHECK_INTERVAL_MS=5000
DB_HEALTHCHECK_FAILURE_THRESHOLD=3
DB_ADMIN_USER=root
DB_ADMIN_PASSWORD=